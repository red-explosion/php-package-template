{
    "name": "red-explosion/package_slug",
    "description": "package_description",
    "license": "MIT",
    "homepage": "https://github.com/red-explosion/package_slug",
    "type": "library",
    "keywords": [
        "red-explosion",
        "package_slug"
    ],
    "authors": [
        {
            "name": "author_name",
            "email": "author@email.com"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-arch": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "RedExplosion\\Skeleton\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RedExplosion\\Skeleton\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --parallel",
        "test:lint": "pint --parallel --test",
        "test:unit": "pest --parallel",
        "test:types": "phpstan",
        "test": [
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
